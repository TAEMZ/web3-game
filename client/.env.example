# Backend API URL (the Express + Socket.IO server). Leave EMPTY only when the
# client and API are served behind one origin via a reverse proxy.
NEXT_PUBLIC_API_URL=http://localhost:3001

# thirdweb client ID — get a free one at https://thirdweb.com/dashboard.
# Required for wallet connect + on-chain features. Add your host to the client's
# "Allowed Domains" in the thirdweb dashboard.
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=

# Public site URL for share links / social (OG) metadata (your production domain).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
