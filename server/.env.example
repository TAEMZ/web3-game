# Postgres. For local dev use your Postgres connection URL (Supabase pooler,
# Render external URL, or a local db). SSL is required for hosted Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME
PGSSL=true

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Session cookie signing secret — generate with: openssl rand -hex 32
SESSION_SECRET=change-me

# Comma-separated usernames granted admin on login (admin console at /admin).
ADMIN_NAMES=

# Optional: URL the Next.js server uses to reach this API during SSR.
# Defaults to NEXT_PUBLIC_API_URL, then http://localhost:3001.
# API_URL_INTERNAL=http://localhost:3001

# Wager platform fee (percentage deducted from winner's pot). Must match the
# value in the ArenaEscrow contract. Default: 15 (i.e. 15%).
HOUSE_FEE_PERCENT=15

# Treasury address that receives wager fees on-chain. Defaults to the deployer
# address if not set. Must be a valid Ethereum address (0x...).
# ARENA_TREASURY_ADDRESS=0x...
