# Postgres. For local dev use your Postgres connection URL (Supabase pooler,
# Render external URL, or a local db). SSL is required for hosted Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME
PGSSL=true

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Session cookie signing secret — generate with: openssl rand -hex 32
SESSION_SECRET=change-me

# Comma-separated usernames granted admin on login (admin console at /admin).
ADMIN_NAMES=

# Optional: URL the Next.js server uses to reach this API during SSR.
# Defaults to NEXT_PUBLIC_API_URL, then http://localhost:3001.
# API_URL_INTERNAL=http://localhost:3001
